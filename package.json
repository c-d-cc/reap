    "test:unit": "bun test tests/unit/",
    "test:e2e": "bun test tests/e2e/",
    "test:scenario": "bun test tests/scenario/",
    "postinstall": "bash scripts/postinstall.sh || true"
  },
  "dependencies": {
    "yaml": "^2.0.0"
  },
  "reap": {
    "autoUpdateMinVersion": "0.16.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
